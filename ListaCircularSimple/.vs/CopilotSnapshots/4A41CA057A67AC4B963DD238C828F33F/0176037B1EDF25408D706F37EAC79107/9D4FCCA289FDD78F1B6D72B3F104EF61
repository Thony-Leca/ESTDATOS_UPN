using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ListaCircularSimple
{
    public class ListaCircularSimple
    {
        Nodo raiz, nuevo, aux, ptr; // ptr = pointer = puntero = direccion direccion = numero

        // Método Constructor
        public ListaCircularSimple() { raiz = null; }

        // Método InsertarLIFO
        public void InsertarLIFO(int dato)
        {
            nuevo = new Nodo();
            nuevo.info = dato;
            if (raiz == null)
            {
                nuevo.sig = nuevo;
                raiz = nuevo;
                aux = nuevo;
            }
            else
            {
                nuevo.sig = raiz;
                aux.sig = nuevo;
                raiz = nuevo;
            }
        }
        // Método InsertarFIFO
        public void InsertarFIFO(int dato)
        {
            nuevo = new Nodo();
            nuevo.info = dato;
            if (raiz == null)
            {
                nuevo.sig = nuevo; 
                raiz = aux = nuevo;
            }
            else
            {
                aux.sig = nuevo; 
                nuevo.sig = raiz; 
                aux = nuevo;
            }
        }

        // Método Recorrido
        public void Recorrido()
        {
            ptr = raiz;
            do
            {
                Console.Write("{0},", ptr.info);
                ptr = ptr.sig;
            } while (ptr != raiz);
        }

        // Método Buscar
        public int Buscar(int dato)
        {
            int resultado = 0;
            ptr = raiz;
            do
            {
                if (ptr.info == dato)
                {
                    resultado = 1; break;
                }
                ptr = ptr.sig;
            } while (ptr != raiz);
            return resultado;
        }

        // Método Eliminar
        public void Eliminar(int dato)
        {
            bool resultado = false;
            if (raiz == null) 
            {
                Console.WriteLine("NO ELIMINADO");
                return;
            }
            if (raiz.info == dato)
            {
                resultado = true;
                if (raiz.sig == raiz)
                {
                    raiz = null;
                }
                else
                {
                    aux = raiz;
                    while (aux.sig != raiz)
                    {
                        aux = aux.sig;
                    }
                    raiz = raiz.sig;
                    aux.sig = raiz;
                }
            }
            else
            {
                ptr = aux = raiz;
                do
                {
                    if (ptr.info == dato)
                    {
                        resultado = true;
                        aux.sig = ptr.sig;
                        break;
                    }
                    aux = ptr;
                    ptr = ptr.sig;
                } while (ptr != raiz);
            }
            Console.WriteLine("{0} ELIMINADO", resultado ? "SI" : "NO");
            if (raiz != null) Recorrido();
        }

        // Método Ordenar
        public void Ordenar()
        {   // > (Ascendente), < (Descendente)
            ptr = raiz;
            while (ptr != raiz)
            {
                aux = raiz;
                while (aux != raiz)
                {
                    if (ptr.info > aux.info)
                    {
                        int temp = ptr.info;
                        ptr.info = aux.info;
                        aux.info = temp;
                    }
                    aux = aux.sig;
                }
                ptr = ptr.sig;
            }
        }
    }
}
