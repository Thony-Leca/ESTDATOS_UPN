using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace ListaCircularDoble
{
    public class ListaDoble
    {
        Nodo raiz1, raiz2, ptr, aux, nuevo;
        // Costructor
        public ListaDoble()
        {
            raiz1 = raiz2 = null;
        }

        // INSERTARLIFO
        public void InsertarLIFO(int dato)
        {
            nuevo = new Nodo();
            nuevo.info = dato;
            if (raiz1 == null)
            {
                nuevo.sig = nuevo.ant = null;
                raiz1 = raiz2 = nuevo;
                aux = nuevo;
            }
            else
            {
                nuevo.sig = raiz1;
                nuevo.ant = raiz2;
                raiz1.ant = nuevo;
                raiz1 = nuevo;
                aux.sig = nuevo;
            }
        }


        // INSERTARFIFO
        public void InsertarFIFO(int dato)
        {

            nuevo = new Nodo();
            nuevo.info = dato;
            if (raiz2 == null)
            {
                nuevo.sig = nuevo.ant = null;
                raiz1 = raiz2 = aux = nuevo;
            }
            else
            {
                nuevo.sig = raiz1;
                nuevo.ant = raiz2;
                raiz2.sig = nuevo;
                raiz2 = nuevo;
                aux = nuevo;
            }
        }


        // RECORRIDO
        public void Recorrido()
        {
            ptr = raiz1;
            Console.WriteLine("\n ---- LISTADO DE ELEMENTOS ----");
            do
            {
                if (ptr == null)
                {
                    Console.WriteLine("Vacía");
                }
                else
                {
                    Console.Write("{0},", ptr.info);
                    ptr = ptr.sig;
                }
            } while (ptr != raiz1);
            Console.WriteLine("");
        }

        // BUSCAR 
        public bool Buscar(int dato)
        {
            bool encontrado = false;
            ptr = raiz1;
            do
            {
                if (ptr.info == dato)
                {
                    encontrado = true;
                }
                else
                {
                    ptr = ptr.sig;
                }
            } while (ptr != raiz1 && !encontrado);
            return encontrado;
        }


        // ELIMINAR
        public bool Eliminar(int dato)
        {

            ptr = raiz1;
            bool encontrado = false;

            if (raiz1 == raiz2 && raiz1.info == dato)
            {
                raiz1 = raiz2 = null;
                return true;
            }

            if (raiz1.info == dato)
            {
                encontrado = true;
                aux = raiz1;
                do
                {
                    aux = aux.sig;
                } while (aux != null && aux.sig != raiz1);
                raiz1 = raiz1.sig;
                raiz1.ant = aux.ant;
                aux.sig = raiz1;
            }
            else if (raiz2.info == dato)
            {
                encontrado = true;
                // Como es doblemente enlazada, el anterior es directamente raiz2.ant. 
                // Evitamos el bucle innecesario que hace que el programa se quede colgado.
                raiz2 = raiz2.ant;
                raiz2.sig = raiz1;
                raiz1.ant = raiz2;
            }
            else
            {
                // Búsqueda
                do
                {
                    if (ptr.info == dato)
                    {
                        encontrado = true;
                    }
                    else { ptr = ptr.sig; }
                } while (ptr != raiz1 && !encontrado);

                if (encontrado)
                {
                    ptr.ant.sig = ptr.sig;
                    ptr.sig.ant = ptr.ant;
                }
            }
                return encontrado;
        }

        // ORDENAR
        public void Ordenar()
        {
            Nodo ptr1, ptr2;
            ptr1 = raiz1;
            do
            {
                ptr2 = raiz1;
                do
                {
                    if (ptr1.info > ptr2.info)
                    {
                        int aux = ptr1.info;
                        ptr1.info = ptr2.info;
                        ptr2.info = aux;
                    }
                    ptr2 = ptr2.sig;
                } while (ptr2 != raiz1);
            } while (ptr1 != raiz1);
                ptr1 = ptr1.sig;
            }
        }
}
