        Nodo raiz1, raiz2, ptr, aux, nuevo;
        // Costructor
        public ListaDoble()
        {
            raiz1 = raiz2 = null;
        }

        // INSERTARLIFO
        public void InsertarLIFO(int dato)
        {
            nuevo = new Nodo();
            nuevo.info = dato;
            if (raiz1 == null)
            {
                nuevo.sig = nuevo.ant = null;
                raiz1 = raiz2 = nuevo;
                aux = nuevo;
            }
            else
            {
                nuevo.sig = raiz1;
                nuevo.ant = raiz2;
                raiz1.ant = nuevo;
                raiz1 = nuevo;
                aux.sig = nuevo;
            }
        }


        // INSERTARFIFO
        public void InsertarFIFO(int dato)
        {

            nuevo = new Nodo();
            nuevo.info = dato;
            if (raiz2 == null)
            {
                nuevo.sig = nuevo.ant = null;
                raiz1 = raiz2 = aux = nuevo;
            }
            else
            {
                nuevo.sig = raiz1;
                nuevo.ant = raiz2;
                raiz2.sig = nuevo;
                raiz2 = nuevo;
                aux = nuevo;
            }
        }


        // RECORRIDO
        public void Recorrido()
        {
            ptr = raiz1;
            Console.WriteLine("\n ---- LISTADO DE ELEMENTOS ----");
            do
            {
                Console.Write("{0},", ptr.info);
                ptr = ptr.sig;
            } while (ptr != raiz1);
            Console.WriteLine("");
        }

        // BUSCAR 
        public bool Buscar(int dato)
        {
            bool encontrado = false;
            ptr = raiz1;
            do
            {
                if (ptr.info == dato)
                {
                    encontrado = true;
                }
                else
                {
                    ptr = ptr.sig;
                }
            } while (ptr != raiz1 && !encontrado);
            return encontrado;
        }


        // ELIMINAR
        public bool Eliminar(int dato)
        {
            ptr = raiz1;
            bool encontrado = false;
            if (raiz1.info == dato)
            {
                encontrado = true;
                aux = raiz1;
                while (aux.sig != raiz1)
                {
                    aux = aux.sig;
                }
                raiz1 = raiz1.sig;
                raiz1.ant = aux.ant;
                aux.sig = raiz1;
            }
            else if (raiz2.info == dato)
            {
                encontrado = true;
                aux = raiz2;
                while (aux.ant != raiz2)
                {
                    aux = aux.ant;
                }
                raiz2 = raiz2.ant;
                raiz2.sig = aux.sig;
                raiz1.ant = raiz2;
                aux.ant = raiz2;
            }
            else
            {
                // Búsqueda
                do
                {
                    if (ptr.info == dato)
                    {
                        encontrado = true;
                    }
                    else { ptr = ptr.sig; }
                } while (ptr != null && !encontrado);

                if (encontrado)
                {
                    ptr.ant.sig = ptr.sig;
                    ptr.sig.ant = ptr.ant;
                }
            }
                return encontrado;
        }


