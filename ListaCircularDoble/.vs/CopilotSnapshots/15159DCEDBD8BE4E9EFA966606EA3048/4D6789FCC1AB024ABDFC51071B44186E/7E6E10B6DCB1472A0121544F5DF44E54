        // ORDENAR
        public void Ordenar()
        {
            Nodo ptr1, ptr2;
            ptr1 = raiz1;
            while (ptr1 != null)
            {
                ptr2 = raiz1;
                while (ptr2 != null)
                {
                    if (ptr1.info > ptr2.info)
                    {
                        int aux = ptr1.info;
                        ptr1.info = ptr2.info;
                        ptr2.info = aux;
                    }
                    ptr2 = ptr2.sig;
                }
                ptr1 = ptr1.sig;
            }
        }
